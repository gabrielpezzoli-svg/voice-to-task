<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0"/>
  <title>VoiceTask</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;800&family=DM+Mono:wght@300;400;500&display=swap" rel="stylesheet"/>
  <style>
    :root {
      --bg: #080810;
      --surface: #10101c;
      --surface2: #18182a;
      --surface3: #202038;
      --border: #ffffff0f;
      --border2: #ffffff18;
      --accent: #7c6aff;
      --accent2: #ff6a9b;
      --accent3: #6affcb;
      --text: #eeeef8;
      --text-dim: #8888b0;
      --text-muted: #44445a;
      --danger: #ff4a6a;
      --success: #4affaa;
      --glow: rgba(124,106,255,0.25);
    }
    * { margin:0; padding:0; box-sizing:border-box; -webkit-tap-highlight-color:transparent; }
    html, body { height:100%; overflow:hidden; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: 'DM Mono', monospace;
      overscroll-behavior: none;
    }
    .amb { position:fixed; border-radius:50%; filter:blur(100px); pointer-events:none; opacity:0.07; }
    .amb-1 { width:500px;height:500px;background:var(--accent);top:-150px;left:-150px; }
    .amb-2 { width:400px;height:400px;background:var(--accent2);bottom:-100px;right:-100px; }

    .screen { display:none; height:100%; flex-direction:column; }
    .screen.active { display:flex; }

    /* LOGIN */
    #screen-login { align-items:center; justify-content:center; padding:1.5rem; }
    .login-card {
      background:var(--surface); border:1px solid var(--border2);
      border-radius:28px; padding:2.5rem 2rem;
      width:100%; max-width:380px; text-align:center;
      position:relative; overflow:hidden;
    }
    .login-card::before {
      content:''; position:absolute; top:0;left:0;right:0; height:2px;
      background:linear-gradient(90deg,var(--accent),var(--accent2),var(--accent3));
    }
    .logo { font-family:'Syne',sans-serif; font-size:2rem; font-weight:800; letter-spacing:-0.03em; margin-bottom:0.2rem; }
    .logo span { color:var(--accent); }
    .login-sub { color:var(--text-dim); font-size:0.72rem; margin-bottom:2rem; letter-spacing:0.04em; }
    .field-label { display:block; font-size:0.65rem; color:var(--text-dim); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:0.4rem; text-align:left; }
    .api-input {
      width:100%; background:var(--surface2); border:1px solid var(--border2);
      border-radius:12px; padding:0.8rem 1rem; color:var(--text);
      font-family:'DM Mono',monospace; font-size:0.8rem; outline:none;
      transition:border-color 0.2s; margin-bottom:1.25rem;
    }
    .api-input:focus { border-color:var(--accent); }
    .api-input::placeholder { color:var(--text-muted); }
    .btn-main {
      width:100%; background:var(--accent); color:#fff; border:none;
      border-radius:14px; padding:0.9rem; font-family:'Syne',sans-serif;
      font-size:0.95rem; font-weight:700; cursor:pointer; transition:all 0.2s;
    }
    .btn-main:hover { background:#8f7eff; box-shadow:0 0 30px var(--glow); transform:translateY(-1px); }
    .login-note { margin-top:0.9rem; font-size:0.68rem; color:var(--text-muted); }
    .login-note a { color:var(--accent); text-decoration:none; }

    /* APP */
    #screen-app { overflow:hidden; }
    .app-header {
      display:flex; align-items:center; justify-content:space-between;
      padding:1rem 1.25rem 0.75rem; flex-shrink:0;
    }
    .header-logo { font-family:'Syne',sans-serif; font-weight:800; font-size:1.05rem; letter-spacing:-0.02em; }
    .header-logo span { color:var(--accent); }
    .btn-logout {
      background:transparent; border:1px solid var(--border2); color:var(--text-dim);
      border-radius:8px; padding:0.35rem 0.7rem; font-family:'DM Mono',monospace;
      font-size:0.65rem; cursor:pointer; transition:all 0.2s;
    }
    .btn-logout:hover { border-color:var(--danger); color:var(--danger); }

    .nav-tabs { display:flex; gap:0.5rem; padding:0 1.25rem 0.75rem; flex-shrink:0; }
    .nav-tab {
      flex:1; background:var(--surface); border:1px solid var(--border);
      border-radius:12px; padding:0.55rem 0.5rem; text-align:center;
      font-size:0.7rem; color:var(--text-dim); cursor:pointer; transition:all 0.2s;
      font-family:'DM Mono',monospace;
    }
    .nav-tab.active { background:var(--accent); border-color:var(--accent); color:#fff; font-weight:500; }

    .page { display:none; flex:1; overflow-y:auto; padding:0 1.25rem 2rem; }
    .page.active { display:block; }

    /* GRID */
    .grid { display:grid; grid-template-columns:1fr 1fr; gap:0.75rem; }

    .card {
      background:var(--surface); border:1px solid var(--border);
      border-radius:20px; padding:1.25rem;
      position:relative; overflow:hidden; transition:all 0.2s;
    }
    .card:active { transform:scale(0.97); }
    .card-label {
      font-size:0.6rem; color:var(--text-dim); letter-spacing:0.1em;
      text-transform:uppercase; margin-bottom:0.75rem;
      display:flex; align-items:center; gap:0.4rem;
    }
    .dot { width:5px; height:5px; border-radius:50%; display:inline-block; }

    /* Calendar card */
    .card-calendar {
      grid-column:1/-1;
      background:linear-gradient(135deg,#13132a 0%,#1a1535 100%);
      border-color:var(--border2);
    }
    .cal-top { display:flex; align-items:flex-start; justify-content:space-between; }
    .cal-day-name { font-family:'Syne',sans-serif; font-size:0.75rem; font-weight:600; color:var(--accent); text-transform:uppercase; letter-spacing:0.1em; margin-bottom:0.2rem; }
    .cal-date-big { font-family:'Syne',sans-serif; font-size:3rem; font-weight:800; line-height:1; letter-spacing:-0.04em; }
    .cal-month { font-size:0.8rem; color:var(--text-dim); margin-top:0.3rem; }
    .cal-badge { background:var(--accent); color:#fff; border-radius:10px; padding:0.3rem 0.7rem; font-size:0.65rem; }
    .cal-mini { display:flex; gap:0.3rem; margin-top:1rem; }
    .cal-mini-day { flex:1; text-align:center; padding:0.4rem 0.2rem; border-radius:8px; font-size:0.6rem; }
    .cal-mini-day .d-name { color:var(--text-muted); margin-bottom:0.2rem; }
    .cal-mini-day .d-num { color:var(--text-dim); }
    .cal-mini-day.today { background:var(--accent); }
    .cal-mini-day.today .d-name, .cal-mini-day.today .d-num { color:#fff; }

    /* Mic card */
    .card-mic {
      grid-column:1/-1;
      background:linear-gradient(135deg,#13132a 0%,#1a1232 100%);
      border-color:var(--border2);
      display:flex; flex-direction:column; align-items:center;
      padding:1.75rem 1.25rem; cursor:pointer;
    }
    .mic-btn {
      width:80px; height:80px; border-radius:50%;
      background:var(--surface3); border:2px solid var(--accent);
      display:flex; align-items:center; justify-content:center;
      font-size:2rem; transition:all 0.3s; margin-bottom:0.9rem;
    }
    .mic-btn.recording { border-color:var(--danger); animation:pulse-mic 1.2s infinite; }
    .mic-btn.processing { border-color:var(--accent3); animation:spin-glow 1.5s linear infinite; }
    @keyframes pulse-mic {
      0%  { box-shadow:0 0 0 0 rgba(255,74,106,0.5); }
      70% { box-shadow:0 0 0 18px rgba(255,74,106,0); }
      100%{ box-shadow:0 0 0 0 rgba(255,74,106,0); }
    }
    @keyframes spin-glow {
      from{ box-shadow:0 0 20px rgba(106,255,203,0.4); transform:rotate(0deg); }
      to  { box-shadow:0 0 20px rgba(106,255,203,0.4); transform:rotate(360deg); }
    }
    .mic-status { font-size:0.72rem; color:var(--text-dim); letter-spacing:0.05em; }
    .mic-status.recording { color:var(--danger); }
    .mic-status.processing { color:var(--accent3); }
    .waveform { display:flex; align-items:center; gap:3px; height:24px; margin-top:0.6rem; opacity:0; transition:opacity 0.3s; }
    .waveform.active { opacity:1; }
    .wbar { width:3px; background:var(--danger); border-radius:2px; animation:wv 0.8s ease-in-out infinite; }
    .wbar:nth-child(1){animation-delay:0s} .wbar:nth-child(2){animation-delay:.1s}
    .wbar:nth-child(3){animation-delay:.2s} .wbar:nth-child(4){animation-delay:.3s}
    .wbar:nth-child(5){animation-delay:.15s} .wbar:nth-child(6){animation-delay:.05s}
    .wbar:nth-child(7){animation-delay:.25s}
    @keyframes wv { 0%,100%{height:4px} 50%{height:18px} }

    /* Stat cards */
    .stat-icon { font-size:1.3rem; margin-bottom:0.4rem; }
    .stat-num { font-family:'Syne',sans-serif; font-size:2.2rem; font-weight:800; line-height:1; letter-spacing:-0.04em; }
    .stat-desc { font-size:0.62rem; color:var(--text-dim); margin-top:0.25rem; line-height:1.4; }

    /* Last note card */
    .card-last { grid-column:1/-1; cursor:pointer; }
    .card-last:hover { border-color:var(--accent); }
    .last-title { font-family:'Syne',sans-serif; font-weight:700; font-size:0.92rem; margin-bottom:0.35rem; line-height:1.3; }
    .last-preview { font-size:0.7rem; color:var(--text-dim); line-height:1.6; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    .last-date { font-size:0.62rem; color:var(--accent); margin-top:0.45rem; }
    .empty-last { font-size:0.72rem; color:var(--text-muted); text-align:center; padding:0.25rem 0; }

    /* NOTES LIST */
    .notes-header { display:flex; align-items:center; justify-content:space-between; margin-bottom:1rem; }
    .notes-title { font-family:'Syne',sans-serif; font-weight:700; font-size:1rem; }
    .badge { background:var(--surface2); border:1px solid var(--border2); border-radius:20px; padding:0.2rem 0.6rem; font-size:0.65rem; color:var(--accent); }
    .notes-list { display:flex; flex-direction:column; gap:0.65rem; }
    .note-card {
      background:var(--surface); border:1px solid var(--border);
      border-radius:16px; padding:1rem 1rem 1rem 1.25rem;
      cursor:pointer; transition:all 0.2s; position:relative; overflow:hidden;
      animation:slideIn 0.3s ease;
    }
    @keyframes slideIn { from{opacity:0;transform:translateY(8px)} to{opacity:1;transform:translateY(0)} }
    .note-card::before { content:''; position:absolute; left:0;top:0;bottom:0; width:3px; background:var(--accent); border-radius:2px 0 0 2px; }
    .note-card:active { transform:scale(0.98); }
    .note-meta { display:flex; gap:0.6rem; margin-bottom:0.4rem; align-items:center; }
    .note-date { font-size:0.62rem; color:var(--accent); }
    .note-time { font-size:0.62rem; color:var(--text-muted); }
    .note-title { font-family:'Syne',sans-serif; font-weight:600; font-size:0.88rem; margin-bottom:0.3rem; line-height:1.3; }
    .note-preview { font-size:0.7rem; color:var(--text-dim); line-height:1.5; display:-webkit-box; -webkit-line-clamp:2; -webkit-box-orient:vertical; overflow:hidden; }
    .note-tags { display:flex; gap:0.35rem; margin-top:0.55rem; flex-wrap:wrap; }
    .tag { background:var(--surface2); border:1px solid var(--border); border-radius:20px; padding:0.18rem 0.5rem; font-size:0.6rem; color:var(--text-dim); }
    .tag.todo { border-color:var(--accent2); color:var(--accent2); }
    .tag.key  { border-color:var(--accent3); color:var(--accent3); }
    .empty-state { text-align:center; padding:3rem 1rem; color:var(--text-muted); }
    .empty-icon { font-size:2.5rem; margin-bottom:0.75rem; opacity:0.4; }
    .empty-text { font-size:0.75rem; line-height:1.6; }

    /* MODAL */
    .modal-overlay { position:fixed; inset:0; background:rgba(0,0,0,0.85); backdrop-filter:blur(8px); z-index:500; display:none; align-items:flex-end; }
    .modal-overlay.open { display:flex; }
    .modal { background:var(--surface); border:1px solid var(--border2); border-radius:24px 24px 0 0; width:100%; max-height:88vh; overflow-y:auto; padding:1.25rem 1.25rem 2rem; animation:slideUp 0.3s ease; }
    @keyframes slideUp { from{transform:translateY(100%)} to{transform:translateY(0)} }
    .modal-handle { width:36px;height:4px;background:var(--border2);border-radius:2px;margin:0 auto 1.25rem; }
    .modal-header { display:flex;align-items:flex-start;justify-content:space-between;gap:1rem;margin-bottom:1.25rem; }
    .modal-title { font-family:'Syne',sans-serif;font-weight:800;font-size:1.1rem;line-height:1.3;flex:1; }
    .modal-date { font-size:0.65rem;color:var(--accent);margin-top:0.25rem; }
    .btn-close { background:var(--surface2);border:1px solid var(--border2);color:var(--text-dim);border-radius:8px;padding:0.35rem 0.55rem;cursor:pointer;font-size:0.9rem;transition:all 0.2s; }
    .btn-close:hover { border-color:var(--danger);color:var(--danger); }
    .modal-sec { margin-bottom:1.25rem; }
    .modal-sec-label { font-size:0.6rem;color:var(--text-dim);letter-spacing:0.12em;text-transform:uppercase;margin-bottom:0.5rem;display:flex;align-items:center;gap:0.5rem; }
    .modal-sec-label::after { content:'';flex:1;height:1px;background:var(--border); }
    .modal-summary { font-size:0.82rem;line-height:1.7;color:var(--text); }
    .modal-points { list-style:none; }
    .modal-points li { padding:0.45rem 0 0.45rem 1.1rem;position:relative;font-size:0.8rem;color:var(--text);border-bottom:1px solid var(--border);line-height:1.5; }
    .modal-points li:last-child { border-bottom:none; }
    .modal-points li::before { content:'›';position:absolute;left:0;color:var(--accent3);font-weight:bold; }
    .todo-list { list-style:none; }
    .todo-item { display:flex;align-items:flex-start;gap:0.65rem;padding:0.55rem 0;border-bottom:1px solid var(--border);font-size:0.8rem; }
    .todo-item:last-child { border-bottom:none; }
    .todo-check { width:18px;height:18px;border-radius:5px;border:1px solid var(--accent2);cursor:pointer;flex-shrink:0;margin-top:1px;transition:all 0.2s;display:flex;align-items:center;justify-content:center; }
    .todo-check.checked { background:var(--accent2);border-color:var(--accent2); }
    .todo-check.checked::after { content:'✓';font-size:0.65rem;color:#fff; }
    .todo-text { flex:1;line-height:1.4; }
    .todo-text.checked { text-decoration:line-through;color:var(--text-muted); }
    .btn-delete { width:100%;background:transparent;border:1px solid var(--danger);color:var(--danger);border-radius:12px;padding:0.75rem;font-family:'DM Mono',monospace;font-size:0.78rem;cursor:pointer;transition:all 0.2s;margin-top:0.5rem; }
    .btn-delete:hover { background:var(--danger);color:#fff; }

    /* TOAST */
    .toast { position:fixed;bottom:2rem;left:50%;transform:translateX(-50%) translateY(100px);background:var(--surface2);border:1px solid var(--border2);border-radius:12px;padding:0.65rem 1.1rem;font-size:0.75rem;color:var(--text);z-index:999;transition:transform 0.3s ease;white-space:nowrap;max-width:90vw;text-align:center; }
    .toast.show { transform:translateX(-50%) translateY(0); }
    .toast.success { border-color:var(--success);color:var(--success); }
    .toast.error { border-color:var(--danger);color:var(--danger); }
    ::-webkit-scrollbar{width:3px} ::-webkit-scrollbar-track{background:transparent} ::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
  </style>
</head>
<body>
<div class="amb amb-1"></div>
<div class="amb amb-2"></div>

<!-- LOGIN -->
<div id="screen-login" class="screen active">
  <div class="login-card">
    <div class="logo">Voice<span>Task</span></div>
    <div class="login-sub">// Ton cerveau externe organisé</div>
    <label class="field-label">Clé API Gemini</label>
    <input type="password" class="api-input" id="api-key-input" placeholder="AIza..." autocomplete="off"/>
    <button class="btn-main" onclick="handleLogin()">Accéder →</button>
    <p class="login-note">Pas de clé ? <a href="https://aistudio.google.com/app/apikey" target="_blank">Obtenir gratuitement ici</a></p>
  </div>
</div>

<!-- APP -->
<div id="screen-app" class="screen">
  <header class="app-header">
    <div class="header-logo">Voice<span>Task</span></div>
    <button class="btn-logout" onclick="handleLogout()">Déconnexion</button>
  </header>
  <div class="nav-tabs">
    <div class="nav-tab active" onclick="showPage('dashboard',this)">🏠 Accueil</div>
    <div class="nav-tab" onclick="showPage('notes',this)">📋 Notes</div>
  </div>

  <!-- DASHBOARD -->
  <div class="page active" id="page-dashboard">
    <div class="grid">

      <!-- Calendrier -->
      <div class="card card-calendar">
        <div class="card-label"><span class="dot" style="background:var(--accent)"></span>Calendrier</div>
        <div class="cal-top">
          <div>
            <div class="cal-day-name" id="cal-day-name"></div>
            <div class="cal-date-big" id="cal-date-big"></div>
            <div class="cal-month" id="cal-month"></div>
          </div>
          <div class="cal-badge">📅 Aujourd'hui</div>
        </div>
        <div class="cal-mini" id="cal-mini"></div>
      </div>

      <!-- Micro -->
      <div class="card card-mic" id="card-mic" onclick="toggleRecord()">
        <div class="card-label"><span class="dot" style="background:var(--accent2)"></span>Note vocale</div>
        <div class="mic-btn" id="mic-btn">🎙️</div>
        <div class="mic-status" id="mic-status">Appuie pour enregistrer</div>
        <div class="waveform" id="waveform">
          <div class="wbar" style="height:6px"></div><div class="wbar" style="height:12px"></div>
          <div class="wbar" style="height:5px"></div><div class="wbar" style="height:18px"></div>
          <div class="wbar" style="height:9px"></div><div class="wbar" style="height:14px"></div>
          <div class="wbar" style="height:7px"></div>
        </div>
      </div>

      <!-- Stat: total notes -->
      <div class="card">
        <div class="card-label"><span class="dot" style="background:var(--accent3)"></span>Total</div>
        <div class="stat-icon">📝</div>
        <div class="stat-num" id="stat-total">0</div>
        <div class="stat-desc">notes<br/>enregistrées</div>
      </div>

      <!-- Stat: tâches -->
      <div class="card">
        <div class="card-label"><span class="dot" style="background:var(--accent2)"></span>À faire</div>
        <div class="stat-icon">✅</div>
        <div class="stat-num" id="stat-todo">0</div>
        <div class="stat-desc">tâches<br/>en attente</div>
      </div>

      <!-- Dernière note -->
      <div class="card card-last" onclick="openLastNote()">
        <div class="card-label"><span class="dot" style="background:var(--accent)"></span>Dernière note</div>
        <div id="last-note-content"><div class="empty-last">Aucune note pour l'instant</div></div>
      </div>

    </div>
  </div>

  <!-- NOTES -->
  <div class="page" id="page-notes">
    <div class="notes-header">
      <div class="notes-title">Mes notes</div>
      <div class="badge" id="note-count">0 note</div>
    </div>
    <div class="notes-list" id="notes-list">
      <div class="empty-state">
        <div class="empty-icon">🎙️</div>
        <div class="empty-text">Aucune note encore.<br/>Va sur l'accueil et appuie sur le micro.</div>
      </div>
    </div>
  </div>
</div>

<!-- MODAL -->
<div class="modal-overlay" id="modal-overlay" onclick="closeModal(event)">
  <div class="modal">
    <div class="modal-handle"></div>
    <div class="modal-header">
      <div>
        <div class="modal-title" id="modal-title"></div>
        <div class="modal-date" id="modal-date"></div>
      </div>
      <button class="btn-close" onclick="closeModalDirect()">✕</button>
    </div>
    <div class="modal-sec">
      <div class="modal-sec-label">Résumé</div>
      <div class="modal-summary" id="modal-summary"></div>
    </div>
    <div class="modal-sec" id="modal-points-sec">
      <div class="modal-sec-label">Points clés</div>
      <ul class="modal-points" id="modal-points"></ul>
    </div>
    <div class="modal-sec" id="modal-todo-sec">
      <div class="modal-sec-label">À faire</div>
      <ul class="todo-list" id="modal-todos"></ul>
    </div>
    <button class="btn-delete" id="modal-delete-btn">🗑 Supprimer cette note</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
  let apiKey='', notes=[], recognition=null;
  let isRecording=false, isProcessing=false;
  let transcript='', currentNoteId=null;

  function init() {
    buildCalendar(); loadNotes();
    const saved = localStorage.getItem('vt_key');
    if (saved) { apiKey=saved; showApp(); }
  }

  function buildCalendar() {
    const now = new Date();
    const days=['Dimanche','Lundi','Mardi','Mercredi','Jeudi','Vendredi','Samedi'];
    const months=['Janvier','Février','Mars','Avril','Mai','Juin','Juillet','Août','Septembre','Octobre','Novembre','Décembre'];
    const dayShort=['Dim','Lun','Mar','Mer','Jeu','Ven','Sam'];
    document.getElementById('cal-day-name').textContent = days[now.getDay()];
    document.getElementById('cal-date-big').textContent = now.getDate();
    document.getElementById('cal-month').textContent = months[now.getMonth()]+' '+now.getFullYear();
    const mini = document.getElementById('cal-mini');
    const start = new Date(now); start.setDate(now.getDate()-now.getDay()+1);
    for(let i=0;i<7;i++){
      const d=new Date(start); d.setDate(start.getDate()+i);
      const today=d.toDateString()===now.toDateString();
      mini.innerHTML+=`<div class="cal-mini-day ${today?'today':''}"><div class="d-name">${dayShort[d.getDay()]}</div><div class="d-num">${d.getDate()}</div></div>`;
    }
  }

  function handleLogin() {
    const k=document.getElementById('api-key-input').value.trim();
    if(!k||!k.startsWith('AIza')){showToast('Clé invalide — doit commencer par AIza...','error');return;}
    apiKey=k; localStorage.setItem('vt_key',k); showApp();
  }
  function handleLogout() {
    localStorage.removeItem('vt_key'); apiKey='';
    document.getElementById('screen-app').classList.remove('active');
    document.getElementById('screen-login').classList.add('active');
    document.getElementById('api-key-input').value='';
  }
  function showApp() {
    document.getElementById('screen-login').classList.remove('active');
    document.getElementById('screen-app').classList.add('active');
    renderAll();
  }

  function showPage(id,tab) {
    document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
    document.querySelectorAll('.nav-tab').forEach(t=>t.classList.remove('active'));
    document.getElementById('page-'+id).classList.add('active');
    tab.classList.add('active');
  }

  function toggleRecord() {
    if(isProcessing) return;
    if(!isRecording) startRecording(); else stopRecording();
  }

  function startRecording() {
    const SR=window.SpeechRecognition||window.webkitSpeechRecognition;
    if(!SR){showToast('Utilise Chrome pour la reconnaissance vocale.','error');return;}
    recognition=new SR(); recognition.lang='fr-FR'; recognition.continuous=true; recognition.interimResults=true;
    transcript='';
    recognition.onresult=e=>{ transcript=Array.from(e.results).map(r=>r[0].transcript).join(' '); };
    recognition.onerror=e=>{showToast('Erreur micro : '+e.error,'error');resetRecorder();};
    recognition.onend=()=>{ if(isRecording) processTranscript(); };
    recognition.start(); isRecording=true;
    document.getElementById('mic-btn').className='mic-btn recording';
    document.getElementById('mic-btn').textContent='⏹️';
    document.getElementById('mic-status').textContent='Enregistrement... (appuie pour arrêter)';
    document.getElementById('mic-status').className='mic-status recording';
    document.getElementById('waveform').classList.add('active');
  }

  function stopRecording() { isRecording=false; if(recognition) recognition.stop(); }

  function resetRecorder() {
    isRecording=false; isProcessing=false;
    document.getElementById('mic-btn').className='mic-btn';
    document.getElementById('mic-btn').textContent='🎙️';
    document.getElementById('mic-status').textContent='Appuie pour enregistrer';
    document.getElementById('mic-status').className='mic-status';
    document.getElementById('waveform').classList.remove('active');
  }

  async function processTranscript() {
    if(!transcript.trim()){showToast('Aucun texte détecté.','error');resetRecorder();return;}
    isProcessing=true;
    document.getElementById('mic-btn').className='mic-btn processing';
    document.getElementById('mic-btn').textContent='⚙️';
    document.getElementById('mic-status').textContent='Analyse IA...';
    document.getElementById('mic-status').className='mic-status processing';
    document.getElementById('waveform').classList.remove('active');
    try {
      const prompt=`Tu es un assistant de productivité. Note vocale brute :\n"${transcript}"\nRéponds UNIQUEMENT en JSON valide, sans texte avant ou après :\n{"titre":"Titre court (max 8 mots)","resume":"Résumé en 2-3 phrases","points_cles":["Point 1","Point 2"],"todo":["Action 1"]}\nSi pas de points clés ou tâches, mets [].`;
      const res=await fetch(`https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=${apiKey}`,{
        method:'POST', headers:{'Content-Type':'application/json'},
        body:JSON.stringify({contents:[{parts:[{text:prompt}]}],generationConfig:{temperature:0.3,maxOutputTokens:800}})
      });
      const data=await res.json();
      if(data.error) throw new Error(data.error.message);
      let raw=data.candidates?.[0]?.content?.parts?.[0]?.text||'';
      raw=raw.replace(/```json|```/g,'').trim();
      const p=JSON.parse(raw);
      const note={
        id:Date.now().toString(), timestamp:new Date().toISOString(), transcript,
        titre:p.titre||'Note sans titre', resume:p.resume||'',
        points_cles:p.points_cles||[], todo:(p.todo||[]).map(t=>({text:t,done:false}))
      };
      notes.unshift(note); saveNotes(); renderAll();
      showToast('Note créée ! ✨','success');
    } catch(err){ showToast('Erreur : '+err.message,'error'); }
    resetRecorder();
  }

  function loadNotes(){try{notes=JSON.parse(localStorage.getItem('vt_notes')||'[]');}catch{notes=[];}}
  function saveNotes(){localStorage.setItem('vt_notes',JSON.stringify(notes));}

  function renderAll(){ renderDashboard(); renderNotesList(); }

  function renderDashboard() {
    document.getElementById('stat-total').textContent=notes.length;
    const pending=notes.reduce((a,n)=>a+(n.todo||[]).filter(t=>!t.done).length,0);
    document.getElementById('stat-todo').textContent=pending;
    const last=notes[0];
    const el=document.getElementById('last-note-content');
    if(!last){ el.innerHTML='<div class="empty-last">Aucune note pour l\'instant</div>'; return; }
    const d=new Date(last.timestamp);
    const date=d.toLocaleDateString('fr-FR',{day:'numeric',month:'short'})+' à '+d.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
    el.innerHTML=`<div class="last-title">${last.titre}</div><div class="last-preview">${last.resume}</div><div class="last-date">${date}</div>`;
  }

  function renderNotesList() {
    const list=document.getElementById('notes-list');
    const count=document.getElementById('note-count');
    count.textContent=notes.length+(notes.length<=1?' note':' notes');
    if(!notes.length){
      list.innerHTML=`<div class="empty-state"><div class="empty-icon">🎙️</div><div class="empty-text">Aucune note encore.<br/>Va sur l'accueil et appuie sur le micro.</div></div>`;
      return;
    }
    list.innerHTML=notes.map(n=>{
      const d=new Date(n.timestamp);
      const date=d.toLocaleDateString('fr-FR',{day:'numeric',month:'short'});
      const time=d.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
      const tc=(n.todo||[]).filter(t=>!t.done).length;
      return `<div class="note-card" onclick="openNote('${n.id}')">
        <div class="note-meta"><span class="note-date">${date}</span><span class="note-time">${time}</span></div>
        <div class="note-title">${n.titre}</div>
        <div class="note-preview">${n.resume}</div>
        <div class="note-tags">
          ${(n.points_cles||[]).length?`<span class="tag key">📌 ${n.points_cles.length} points</span>`:''}
          ${tc?`<span class="tag todo">✅ ${tc} tâche${tc>1?'s':''}</span>`:''}
        </div>
      </div>`;
    }).join('');
  }

  function openLastNote(){ if(notes[0]) openNote(notes[0].id); }

  function openNote(id) {
    const n=notes.find(x=>x.id===id); if(!n) return;
    currentNoteId=id;
    const d=new Date(n.timestamp);
    const dateStr=d.toLocaleDateString('fr-FR',{weekday:'long',day:'numeric',month:'long'})+' à '+d.toLocaleTimeString('fr-FR',{hour:'2-digit',minute:'2-digit'});
    document.getElementById('modal-title').textContent=n.titre;
    document.getElementById('modal-date').textContent=dateStr;
    document.getElementById('modal-summary').textContent=n.resume;
    const ps=document.getElementById('modal-points-sec');
    if((n.points_cles||[]).length){
      document.getElementById('modal-points').innerHTML=n.points_cles.map(p=>`<li>${p}</li>`).join('');
      ps.style.display='block';
    } else ps.style.display='none';
    const ts=document.getElementById('modal-todo-sec');
    if((n.todo||[]).length){
      document.getElementById('modal-todos').innerHTML=n.todo.map((t,i)=>`
        <li class="todo-item">
          <div class="todo-check ${t.done?'checked':''}" onclick="toggleTodo('${id}',${i})"></div>
          <span class="todo-text ${t.done?'checked':''}">${t.text}</span>
        </li>`).join('');
      ts.style.display='block';
    } else ts.style.display='none';
    document.getElementById('modal-delete-btn').onclick=()=>deleteNote(id);
    document.getElementById('modal-overlay').classList.add('open');
  }

  function closeModal(e){ if(e.target===document.getElementById('modal-overlay')) closeModalDirect(); }
  function closeModalDirect(){ document.getElementById('modal-overlay').classList.remove('open'); currentNoteId=null; }

  function toggleTodo(nid,idx){
    const n=notes.find(x=>x.id===nid); if(!n) return;
    n.todo[idx].done=!n.todo[idx].done; saveNotes(); renderAll(); openNote(nid);
  }

  function deleteNote(id){
    notes=notes.filter(n=>n.id!==id); saveNotes(); renderAll(); closeModalDirect();
    showToast('Note supprimée.','success');
  }

  function showToast(msg,type=''){
    const t=document.getElementById('toast');
    t.textContent=msg; t.className='toast '+type;
    t.classList.add('show'); setTimeout(()=>t.classList.remove('show'),3000);
  }

  init();
</script>
</body>
</html>
